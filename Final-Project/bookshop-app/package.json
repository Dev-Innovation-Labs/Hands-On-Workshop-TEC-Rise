{
    "name": "bookshop-tecrise",
    "version": "1.0.0",
    "description": "TEC Rise Bookshop — SAP CAP Application",
    "scripts": {
        "start": "cds-serve",
        "watch": "cds watch",
        "watch:local": "CDS_ENV=local cds watch",
        "build": "cds build --production",
        "test": "jest --silent"
    },
    "dependencies": {
        "@sap/cds": "^9.8",
        "express": "^4"
    },
    "devDependencies": {
        "@cap-js/sqlite": "^2",
        "@sap/cds-dk": "^9",
        "jest": "^29"
    },
    "cds": {
        "requires": {
            "db": {
                "kind": "sqlite",
                "[production]": {
                    "kind": "hana"
                }
            },
            "auth": {
                "kind": "mocked",
                "[production]": {
                    "kind": "xsuaa"
                }
            }
        },
        "log": {
            "level": "info"
        },
        "server": {
            "index": false
        }
    }
}
