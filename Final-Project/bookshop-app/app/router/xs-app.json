{
  "welcomeFile": "/books/webapp/index.html",
  "authenticationMethod": "route",
  "sessionTimeout": 30,
  "logout": {
    "logoutEndpoint": "/do/logout"
  },
  "routes": [
    {
      "source": "^/health$",
      "destination": "srv-api",
      "authenticationType": "none"
    },
    {
      "source": "^/catalog/(.*)$",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/admin/(.*)$",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^/books/(.*)$",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    },
    {
      "source": "^(.*)$",
      "destination": "srv-api",
      "authenticationType": "xsuaa"
    }
  ]
}
